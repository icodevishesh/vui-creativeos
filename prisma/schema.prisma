// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & ORGANIZATION MODELS
// ============================================

enum UserType {
  ADMIN_OWNER
  CLIENT
  ORGANIZATION_MEMBER
}

enum MemberRole {
  ADMIN
  CREATIVE_LEAD
  TEAM_LEAD
  SALESPERSON
  ACCOUNT_MANAGER
  COPYWRITER
  CONTENT_WRITER
  GRAPHIC_DESIGNER
  VIDEO_EDITOR
  SOCIAL_MEDIA_MANAGER
  SEO_SPECIALIST
}

model User {
  id            String   @id @default(cuid()) @map("_id")
  email         String   @unique
  password      String
  name          String
  phone         String?
  userType      UserType
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  roles         MemberRole[]

  // Relations
  ownedOrganizations  Organization[]     @relation("OrganizationOwner")
  memberships         OrganizationMember[]
  clientProfiles      ClientProfile[]
  assignedProjects    ProjectTeamMember[]
  createdTasks        Task[]             @relation("TaskCreator")
  createdProjects     Project[]          @relation("ProjectCreator")
  assignedTasks       Task[]             @relation("TaskAssignee")
  writerTasks         Task[]             @relation("TaskWriter")
  editorTasks         Task[]             @relation("TaskEditor")
  designerTasks       Task[]             @relation("TaskDesigner")
  videoEditorTasks    Task[]             @relation("TaskVideoEditor")
  assignedSubTasks    SubTask[]
  meetingLogs         MeetingLog[]
  comments            Comment[]
  notifications       Notification[]
  uploadedAssets      Asset[]        @relation("UploadedAssets")
  calendars           Calendar[]     @relation("WriterCalendars")

  @@index([userType])
}

model Organization {
  id          String   @id @default(cuid()) @map("_id")
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  owner       User     @relation("OrganizationOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId     String

  members     OrganizationMember[]
  clients     ClientProfile[]
  projects    Project[]
  customRoles CustomRole[]
  tasks       Task[]


  @@index([ownerId])
}

model OrganizationMember {
  id        String     @id @default(cuid()) @map("_id")
  roles     MemberRole[]
  isActive  Boolean    @default(true)
  joinedAt  DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relations
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String

  customRole   CustomRole? @relation(fields: [customRoleId], references: [id])
  customRoleId String?

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

// For dynamic/custom roles beyond predefined ones
model CustomRole {
  id             String   @id @default(cuid()) @map("_id")
  name           String
  description    String?
  permissions    Json     // Store permissions as JSON
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String

  members OrganizationMember[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

// ============================================
// CLIENT MODELS
// ============================================

enum ClientStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum EngagementType {
  RETAINER
  PROJECT_BASED
}

enum ServiceType {
  SOCIAL_MEDIA
  PAID_MEDIA
  INFLUENCER_MARKETING
  EMAIL_MARKETING
  WHATSAPP_MARKETING
  SEO
  CONTENT_CREATION
  BRANDING
  WEB_DEVELOPMENT
}

model ClientProfile {
  id               String         @id @default(cuid()) @map("_id")
  companyName      String
  contactPerson    String
  email            String
  phone            String
  industry         String
  engagementType   EngagementType
  status           ClientStatus   @default(PENDING)
  onboardingNotes  String?
  requirementNotes String?
  competitors      Json?
  socialLinks      Json?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  // Relations
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String

  managedBy      String? // User ID of account manager of allocated team
  defaultService ServiceType @default(SOCIAL_MEDIA)
  isScopeFinalized Boolean @default(false)
  services       ClientService[]
  teamMembers    ClientTeamMember[]
  scopeOfWork    ScopeOfWork[]
  documents      ClientDocument[]
  meetingLogs    MeetingLog[]
  projects       Project[]
  tasks          Task[]
  subTasks       SubTask[]
  ganttTasks     GanttTask[]
  calendarObjective String?

  ganttLinks     GanttLink[]
  assets         Asset[]
  folder         Folder?
  calendars      Calendar[]

  @@index([organizationId])
  @@index([userId])
  @@index([status])
}

model ClientService {
  id        String      @id @default(cuid()) @map("_id")
  service   ServiceType
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())

  client   ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String

  @@unique([clientId, service])
  @@index([clientId])
}

model ClientTeamMember {
  id        String   @id @default(cuid()) @map("_id")
  userId    String
  userName  String
  userRole  String
  createdAt DateTime @default(now())

  client   ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String

  @@index([clientId])
  @@index([userId])
}

// ============================================
// SCOPE OF WORK
// ============================================

model ScopeOfWork {
  id          String      @id @default(cuid()) @map("_id")
  service     ServiceType
  description String
  details     Json? // Store platform-specific details as JSON
  budget      Float?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  client   ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String

  @@index([clientId])
  @@index([service])
}

// ============================================
// DOCUMENTS
// ============================================

enum DocumentType {
  BRAND_GUIDELINES
  STRATEGY_DECK
  SOP
  CONTRACT
  PROPOSAL
  REPORT
  OTHER
}

model ClientDocument {
  id          String       @id @default(cuid()) @map("_id")
  fileName    String
  fileUrl     String
  fileSize    Int?
  mimeType    String?
  type        DocumentType @default(OTHER)
  description String?
  uploadedAt  DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  client   ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String

  @@index([clientId])
  @@index([type])
}

// ============================================
// MEETING LOGS
// ============================================

model MeetingLog {
  id          String   @id @default(cuid()) @map("_id")
  title       String
  notes       String
  meetingDate DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client      ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId    String
  createdBy   User          @relation(fields: [createdById], references: [id])
  createdById String

  attendees  Json? // Store attendee IDs/names as JSON

  @@index([clientId])
  @@index([meetingDate])
}

// ============================================
// PROJECT & TASK MANAGEMENT
// ============================================

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  REVIEW
  COMPLETED
  ON_HOLD
  CANCELLED
}

model Project {
  id          String        @id @default(cuid()) @map("_id")
  name        String
  description String?
  status      ProjectStatus @default(PLANNING)
  startDate   DateTime?
  endDate     DateTime?
  budget      Float?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  client         ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId       String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  createdBy      User?         @relation("ProjectCreator", fields: [createdById], references: [id])
  createdById    String?

  teamMembers ProjectTeamMember[]
  tasks       Task[]
  subTasks    SubTask[]
  approvals   Approval[]

  ganttTasks  GanttTask[]
  ganttLinks  GanttLink[]

  @@index([clientId])
  @@index([organizationId])
  @@index([status])
}

model ProjectTeamMember {
  id        String   @id @default(cuid()) @map("_id")
  role      String
  joinedAt  DateTime @default(now())

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

enum TaskStatus {
  OPEN
  OPENED
  IN_PROGRESS
  ON_HOLD
  INTERNAL_REVIEW
  CLIENT_REVIEW
  APPROVED
  REJECTED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Task {
  id          String       @id @default(cuid()) @map("_id")
  title       String
  description String?
  status      TaskStatus   @default(OPEN)
  priority    TaskPriority @default(MEDIUM)
  mediaUrls   String[]
  feedbacks   String[]
  countSubTask Int         @default(0)
  
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  client      ClientProfile @relation(fields: [clientId], references: [id])
  clientId    String
  organization Organization @relation(fields: [organizationId], references: [id])
  organizationId String

  createdBy   User?   @relation("TaskCreator", fields: [createdById], references: [id])
  createdById String?

  assignedTo   User?   @relation("TaskAssignee", fields: [assignedToId], references: [id])
  assignedToId String?

  // Role-specific assignees
  writer          User?      @relation("TaskWriter", fields: [writerId], references: [id])
  writerId        String?
  editor          User?      @relation("TaskEditor", fields: [editorId], references: [id])
  editorId        String?
  designer        User?      @relation("TaskDesigner", fields: [designerId], references: [id])
  designerId      String?
  videoEditor     User?      @relation("TaskVideoEditor", fields: [videoEditorId], references: [id])
  videoEditorId   String?

  // Per-role statuses
  writerStatus      TaskStatus @default(OPEN)
  editorStatus      TaskStatus @default(OPEN)
  designerStatus    TaskStatus @default(OPEN)
  videoEditorStatus TaskStatus @default(OPEN)

  // Content bucket link
  contentBucket   CalendarBucket? @relation("TaskBucket", fields: [contentBucketId], references: [id])
  contentBucketId String?

  // Links a designer/video-editor task to its specific copy
  calendarCopy    CalendarCopy? @relation("DesignerTask", fields: [calendarCopyId], references: [id])
  calendarCopyId  String?

  subTasks    SubTask[]
  comments    Comment[]
  attachments TaskAttachment[]
  assets      Asset[]          @relation("TaskAssets")
  writerContent   WriterContent?
  designerContent DesignerContent?

  calendar   Calendar? @relation(fields: [calendarId], references: [id])
  calendarId String?

  @@index([projectId])
  @@index([clientId])
  @@index([assignedToId])
  @@index([status])
  @@index([endDate])
  @@index([contentBucketId])
}

enum ReviewerType {
  CLIENT
  ADMIN
  TEAM_LEAD
  ACCOUNT_MANAGER
}

model WriterContent {
  id        String   @id @default(cuid()) @map("_id")
  content   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String   @unique
}

model DesignerContent {
  id        String   @id @default(cuid()) @map("_id")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String   @unique
}

model SubTask {
  id          String       @id @default(cuid()) @map("_id")
  title       String
  description String?
  status      TaskStatus   @default(OPEN)
  
  mediaUrls   String[]     // ["url1", "url2", "url3"]
  feedbacks   String[]     // ["feedback1", "feedback2", "feedback3"]
  
  startDate   DateTime?    // in progress date
  endDate     DateTime?    // completed date
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  mainTask    Task @relation(fields: [mainTaskId], references: [id], onDelete: Cascade)
  mainTaskId  String

  project     Project      @relation(fields: [projectId], references: [id])
  projectId   String
  client      ClientProfile @relation(fields: [clientId], references: [id])
  clientId    String

  assignedTo   User?   @relation(fields: [assignedToId], references: [id])
  assignedToId String?

  // Content bucket link
  contentBucket   CalendarBucket? @relation("SubTaskBucket", fields: [contentBucketId], references: [id])
  contentBucketId String?

  // Reviewer info — who gave feedback / rejected
  reviewerId    String?       // User ID of the reviewer
  reviewerType  ReviewerType? // client, admin, team_lead, account_manager
  reviewerName  String?       // name of the reviewer

  @@index([mainTaskId])
  @@index([projectId])
  @@index([clientId])
  @@index([reviewerId])
  @@index([contentBucketId])
}

model Comment {
  id        String   @id @default(cuid()) @map("_id")
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId String

  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId String

  @@index([taskId])
  @@index([authorId])
}

model TaskAttachment {
  id           String   @id @default(cuid()) @map("_id")
  fileName     String
  fileUrl      String
  fileSize     Int?
  mimeType     String?
  platform     String?
  platformType String?
  uploadedAt   DateTime @default(now())

  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId String

  @@index([taskId])
}

// ============================================
// GANTT CHART MODELS
// ============================================

model GanttTask {
  id        String    @id @default(cuid()) @map("_id")
  text      String    @default("New Task")
  start     DateTime  @default(now())
  end       DateTime?
  duration  Int       @default(1)
  progress  Int       @default(0)
  type      String    @default("task") // task | summary | milestone
  parent    String?   // ID of parent GanttTask for nesting
  orderId   Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  client    ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId  String

  @@index([projectId])
  @@index([clientId])
  @@index([orderId])
}

model GanttLink {
  id        String @id @default(cuid()) @map("_id")
  source    String
  target    String
  type      String @default("e2s") // e2s | s2s | e2e | s2e
  projectId String
  clientId  String

  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  client    ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([clientId])
}

// ============================================
// APPROVAL WORKFLOW
// ============================================

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  REVISION_REQUESTED
}

model Approval {
  id          String         @id @default(cuid()) @map("_id")
  title       String
  description String?
  status      ApprovalStatus @default(PENDING)
  submittedAt DateTime       @default(now())
  reviewedAt  DateTime?
  feedback    String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  submittedBy   String // User ID
  reviewedBy    String? // User ID

  attachments Json? // Store file URLs as JSON

  @@index([projectId])
  @@index([status])
}

// ============================================
// NOTIFICATIONS
// ============================================

enum NotificationType {
  TASK_ASSIGNED
  TASK_COMPLETED
  APPROVAL_REQUESTED
  APPROVAL_REVIEWED
  MEETING_SCHEDULED
  DOCUMENT_UPLOADED
  COMMENT_ADDED
  PROJECT_STATUS_CHANGED
}

model Notification {
  id        String           @id @default(cuid()) @map("_id")
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  link      String? // Link to relevant resource
  createdAt DateTime         @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@index([userId, isRead])
  @@index([createdAt])
}

// ============================================
// FILE REPOSITORY
// ============================================

model Folder {
  id        String   @id @default(cuid()) @map("_id")
  name      String   // sanitized disk folder name
  createdAt DateTime @default(now())

  client   ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String        @unique
}

model Asset {
  id           String   @id @default(cuid()) @map("_id")
  assetName    String
  fileUrl      String
  fileType     String   // MIME type
  fileSize     Int?
  uploadedAt   DateTime @default(now())

  client       ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId     String

  uploadedBy   User   @relation("UploadedAssets", fields: [uploadedById], references: [id])
  uploadedById String

  // Content bucket link
  contentBucket   CalendarBucket? @relation("AssetBucket", fields: [contentBucketId], references: [id])
  contentBucketId String?

  // Task link — media uploaded for a specific task
  task   Task?   @relation("TaskAssets", fields: [taskId], references: [id])
  taskId String?

  @@index([clientId])
  @@index([uploadedById])
  @@index([uploadedAt])
  @@index([contentBucketId])
  @@index([taskId])
}


// ============================================
// ANALYTICS & REPORTING (Optional)
// ============================================

model ActivityLog {
  id          String   @id @default(cuid()) @map("_id")
  userId      String
  action      String
  entityType  String // e.g., "Project", "Task", "Client"
  entityId    String
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ============================================
// CALENDAR MODELS
// ============================================

model Calendar {
  id               String           @id @default(cuid()) @map("_id")
  name             String
  objective        String?
  status           String?          @default("DRAFT") // DRAFT, ACTIVE, COMPLETED
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  client           ClientProfile    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId         String
  
  writer           User             @relation("WriterCalendars", fields: [writerId], references: [id])
  writerId         String

  buckets          CalendarBucket[]
  copies           CalendarCopy[]

  tasks            Task[]
  taskId           String?

  @@index([clientId])
  @@index([writerId])
}

model CalendarBucket {
  id          String   @id @default(cuid()) @map("_id")
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  calendar    Calendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  calendarId  String

  copies        CalendarCopy[]
  tasks         Task[]    @relation("TaskBucket")
  subTasks      SubTask[] @relation("SubTaskBucket")
  assets        Asset[]   @relation("AssetBucket")

  @@index([calendarId])
}

model CalendarCopy {
  id             String         @id @default(cuid()) @map("_id")
  content        String
  caption        String?
  hashtags       String?
  publishDate    DateTime?
  publishTime    String?        // Store as string like "HH:mm"
  platforms      String[]
  mediaType      String?
  status         String         @default("DRAFT") // DRAFT, UNDER_REVIEW, APPROVED
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  calendar       Calendar       @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  calendarId     String
  bucket         CalendarBucket @relation(fields: [bucketId], references: [id], onDelete: Cascade)
  bucketId       String

  // Designer/video-editor tasks created from this copy after client approval
  designerTasks  Task[] @relation("DesignerTask")

  @@index([calendarId])
  @@index([bucketId])
}
